<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.PortalConnect"
        android:extractNativeLibs="true">

        <activity
            android:name="com.example.operaproxy.OnboardingActivity"
            android:exported="true"
            android:theme="@style/Theme.PortalConnect">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.operaproxy.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name="com.example.operaproxy.MainSettingsActivity"
            android:label="@string/settings_title" />

        <activity
            android:name="com.example.operaproxy.AdvancedSettingsActivity"
            android:label="@string/advanced_settings_title"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name="com.example.operaproxy.AppSelectionActivity"
            android:label="@string/app_selector_btn" />

        <activity
            android:name="com.example.operaproxy.AutostartSettingsActivity"
            android:label="@string/pref_autostart_menu" />

        <service
            android:name="com.example.operaproxy.ProxyVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:process=":vpn"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <service
            android:name="com.example.operaproxy.ProxyTileService"
            android:exported="true"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <receiver
            android:name="com.example.operaproxy.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.example.operaproxy.WifiConnectivityReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- Базовый ресивер виджета -->
        <receiver
            android:name="com.example.operaproxy.PortalWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="STATUS_UPDATE" />
                <action android:name="TRAFFIC_UPDATE" />
                <action android:name="com.portal.connect.WIDGET_CLICK" />
            </intent-filter>
        </receiver>

        <!-- Компактный виджет -->
        <receiver
            android:name="com.example.operaproxy.PortalWidgetCompactProvider"
            android:label="@string/widget_compact_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="STATUS_UPDATE" />
                <action android:name="TRAFFIC_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/portal_widget_compact_info" />
        </receiver>

        <!-- Средний виджет -->
        <receiver
            android:name="com.example.operaproxy.PortalWidgetMediumProvider"
            android:label="@string/widget_medium_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="STATUS_UPDATE" />
                <action android:name="TRAFFIC_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/portal_widget_medium_info" />
        </receiver>

        <!-- Большой виджет -->
        <receiver
            android:name="com.example.operaproxy.PortalWidgetLargeProvider"
            android:label="@string/widget_large_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="STATUS_UPDATE" />
                <action android:name="TRAFFIC_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/portal_widget_large_info" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.operaproxy.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
