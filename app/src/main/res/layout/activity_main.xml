<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/svLog"
        android:background="?attr/theme_log_background"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <TextView
            android:textSize="11sp"
            android:textColor="?attr/theme_log_text"
            android:id="@+id/tvLog"
            android:padding="12dp"
            android:focusable="false"
            android:clickable="false"
            android:longClickable="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="400dp"
            android:textIsSelectable="false"
            android:alpha="0.9"
            android:fontFamily="monospace"/>
    </ScrollView>
    <View
        android:background="@drawable/bg_log_overlay"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:descendantFocusability="afterDescendants"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:theme="@style/ThemeOverlay.Toolbar"
            android:background="?attr/theme_background_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:title="@string/app_name"
                app:titleTextColor="?attr/theme_text_primary"/>
        </com.google.android.material.appbar.AppBarLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <LinearLayout
                android:orientation="vertical"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:textSize="11sp"
                    android:textColor="?attr/theme_text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"
                    android:text="@string/current_server"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/theme_accent"
                    android:id="@+id/tvServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/current_server_unknown"/>
                <TextView
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/theme_accent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/region_title"/>
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/rgCountry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioButton
                        android:textSize="10sp"
                        android:textColor="?attr/theme_text_primary"
                        android:gravity="center"
                        android:id="@+id/rbAuto"
                        android:background="@drawable/bg_region_selector_tv"
                        android:padding="8dp"
                        android:focusable="true"
                        android:nextFocusRight="@+id/rbEU"
                        android:nextFocusDown="@+id/btnToggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:button="@null"
                        android:text="@string/region_auto"
                        android:drawableTop="@android:drawable/ic_menu_rotate"
                        android:drawablePadding="2dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"/>
                    <RadioButton
                        android:textSize="11sp"
                        android:textColor="?attr/theme_text_primary"
                        android:gravity="center"
                        android:id="@+id/rbEU"
                        android:background="@drawable/bg_region_selector_tv"
                        android:padding="10dp"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/rbAuto"
                        android:nextFocusRight="@+id/rbAS"
                        android:nextFocusDown="@+id/btnToggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:text="@string/region_eu"
                        android:drawableTop="@drawable/ic_flag_eu"
                        android:drawablePadding="4dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"/>
                    <RadioButton
                        android:textSize="11sp"
                        android:textColor="?attr/theme_text_primary"
                        android:gravity="center"
                        android:id="@+id/rbAS"
                        android:background="@drawable/bg_region_selector_tv"
                        android:padding="10dp"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/rbEU"
                        android:nextFocusRight="@+id/rbAM"
                        android:nextFocusDown="@+id/btnToggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:text="@string/region_as"
                        android:drawableTop="@drawable/ic_flag_asia"
                        android:drawablePadding="4dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"/>
                    <RadioButton
                        android:textSize="11sp"
                        android:textColor="?attr/theme_text_primary"
                        android:gravity="center"
                        android:id="@+id/rbAM"
                        android:background="@drawable/bg_region_selector_tv"
                        android:padding="10dp"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/rbAS"
                        android:nextFocusDown="@+id/btnToggle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:text="@string/region_am"
                        android:drawableTop="@drawable/ic_flag_us"
                        android:drawablePadding="4dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"/>
                </RadioGroup>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="?attr/theme_text_secondary"
                        android:gravity="center"
                        android:id="@+id/tvPingEU"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="?attr/theme_text_secondary"
                        android:gravity="center"
                        android:id="@+id/tvPingAS"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="10sp"
                        android:textColor="?attr/theme_text_secondary"
                        android:gravity="center"
                        android:id="@+id/tvPingAM"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.google.android.material.button.MaterialButton
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/theme_text_primary"
                        android:id="@+id/btnToggle"
                        android:padding="0dp"
                        android:focusable="true"
                        android:nextFocusUp="@+id/rbEU"
                        android:layout_width="168dp"
                        android:layout_height="168dp"
                        android:text="@string/btn_start"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null"
                        app:background="@drawable/bg_btn_glass_selector"
                        app:backgroundTint="@null"
                        app:elevation="12dp"
                        app:strokeWidth="0dp"
                        style="@style/Widget.MaterialComponents.Button"/>
                </FrameLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/theme_bottom_bar_bg"
                android:paddingLeft="24dp"
                android:paddingTop="16dp"
                android:paddingRight="24dp"
                android:paddingBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="32dp">
                        <TextView
                            android:textSize="11sp"
                            android:textColor="?attr/theme_text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/traffic_in"/>
                        <TextView
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/theme_accent"
                            android:id="@+id/tvTrafficIn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="11sp"
                            android:textColor="?attr/theme_text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/traffic_out"/>
                        <TextView
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/theme_accent"
                            android:id="@+id/tvTrafficOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="11sp"
                        android:textColor="?attr/theme_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/connection_time"/>
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/theme_accent"
                        android:id="@+id/tvConnectionTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:textSize="12sp"
                    android:id="@+id/btnTestLatency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/btn_test_latency"
                    app:strokeColor="?attr/theme_accent"
                    app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>
