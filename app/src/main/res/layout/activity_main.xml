<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Фоновая консоль (Лог) -->
    <ScrollView
        android:id="@+id/svLog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/theme_log_background"
        android:descendantFocusability="blocksDescendants"
        android:fillViewport="true"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.9"
            android:fontFamily="monospace"
            android:minHeight="400dp"
            android:padding="12dp"
            android:textColor="?attr/theme_log_text"
            android:textSize="11sp"
            android:focusable="false"
            android:clickable="false"
            android:textIsSelectable="false" />
    </ScrollView>

    <!-- Затемнение лога -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_log_overlay"
        android:clickable="false"
        android:focusable="false" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/theme_background_card"
            android:theme="@style/ThemeOverlay.Toolbar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:title="@string/app_name"
                app:titleTextColor="?attr/theme_text_primary" />
        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- Инфо о сервере и выбор региона -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_server"
                    android:textColor="?attr/theme_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_server_unknown"
                    android:textColor="?attr/theme_accent"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/region_title"
                    android:textColor="?attr/theme_accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rgCountry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbAuto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_region_selector_tv"
                        android:button="@null"
                        android:checked="true"
                        android:drawableTop="@android:drawable/ic_menu_rotate"
                        android:drawablePadding="2dp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="@string/region_auto"
                        android:textColor="?attr/theme_text_primary"
                        android:textSize="10sp" />

                    <RadioButton
                        android:id="@+id/rbEU"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_region_selector_tv"
                        android:button="@null"
                        android:drawableTop="@drawable/ic_flag_eu"
                        android:drawablePadding="4dp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="@string/region_eu"
                        android:textColor="?attr/theme_text_primary"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/rbAS"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_region_selector_tv"
                        android:button="@null"
                        android:drawableTop="@drawable/ic_flag_asia"
                        android:drawablePadding="4dp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="@string/region_as"
                        android:textColor="?attr/theme_text_primary"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/rbAM"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_region_selector_tv"
                        android:button="@null"
                        android:drawableTop="@drawable/ic_flag_us"
                        android:drawablePadding="4dp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="@string/region_am"
                        android:textColor="?attr/theme_text_primary"
                        android:textSize="11sp" />
                </RadioGroup>

                <!-- Пинги под регионами -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    <TextView android:id="@+id/tvPingEU" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—" android:textColor="?attr/theme_text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/tvPingAS" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—" android:textColor="?attr/theme_text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/tvPingAM" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="—" android:textColor="?attr/theme_text_secondary" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Центральная кнопка Старт/Стоп -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggle"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="168dp"
                    android:layout_height="168dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/btn_start"
                    android:textColor="?attr/theme_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:background="@drawable/bg_btn_glass_selector"
                    app:backgroundTint="@null"
                    app:elevation="12dp"
                    app:strokeWidth="0dp" />
            </LinearLayout>

            <!-- Нижняя панель статистики -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/theme_bottom_bar_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingLeft="24dp"
                android:paddingTop="16dp"
                android:paddingRight="24dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="32dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/traffic_in"
                            android:textColor="?attr/theme_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvTrafficIn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="?attr/theme_accent"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/traffic_out"
                            android:textColor="?attr/theme_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvTrafficOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="?attr/theme_accent"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/connection_time"
                        android:textColor="?attr/theme_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvConnectionTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="—"
                        android:textColor="?attr/theme_accent"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestLatency"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/btn_test_latency"
                    android:textSize="12sp"
                    app:strokeColor="?attr/theme_accent"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>
