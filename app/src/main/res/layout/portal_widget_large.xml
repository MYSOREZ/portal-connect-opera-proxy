<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:background="@color/widget_bg"
    android:padding="12dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="@string/app_name"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/widget_accent"
            android:layout_gravity="center_horizontal"
            android:id="@+id/widgetStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/widget_status_disconnected"
            android:letterSpacing="0.05"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Регион"/>
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/widgetRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"/>
            </LinearLayout>
            <TextView
                android:background="@color/divider"
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:text=""/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пинг"/>
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/widget_accent"
                    android:id="@+id/widgetPing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:background="@color/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:text=""/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/traffic_in"/>
                <TextView
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/widget_accent"
                    android:id="@+id/widgetTrafficIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/traffic_out"/>
                <TextView
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:id="@+id/widgetTrafficOut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center_horizontal"
            android:id="@+id/widgetTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="00:00:00"
            android:fontFamily="monospace"/>
    </LinearLayout>
</FrameLayout>
