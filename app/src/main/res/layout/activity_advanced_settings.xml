<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/theme_background_app"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:theme="@style/ThemeOverlay.Toolbar"
        android:background="?attr/theme_background_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/advanced_settings_title"
            app:titleTextColor="?attr/theme_text_primary"/>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/theme_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/AdvSettings_localnetwork"/>
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="?attr/theme_text_secondary"
                android:id="@+id/tilBindAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/pref_bind_address"
                app:boxStrokeColor="?attr/theme_accent"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconMode="custom"
                app:endIconTint="?attr/theme_text_secondary"
                app:expandedHintEnabled="false"
                app:hintTextColor="?attr/theme_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/etBindAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pref_bind_address_hint"
                    android:inputType="text"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/swProxyOnly"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_proxy_only"
                    android:layout_weight="1"
                    android:paddingEnd="4dp"/>
                <ImageView
                    android:id="@+id/ivHelpProxyOnly"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:contentDescription="Справка"
                    android:layout_marginStart="4dp"
                    app:tint="?attr/theme_text_secondary"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/swSocksMode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_socks_mode"
                    android:layout_weight="1"
                    android:paddingEnd="4dp"/>
                <ImageView
                    android:id="@+id/ivHelpSocksMode"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:contentDescription="Справка"
                    android:layout_marginStart="4dp"
                    app:tint="?attr/theme_text_secondary"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textColor="?attr/theme_text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/whitelist_preset_hint"/>
            <com.google.android.material.button.MaterialButton
                android:textColor="?attr/theme_accent"
                android:id="@+id/btnWhitelistPreset"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:text="@string/btn_whitelist_preset"
                android:textAllCaps="false"
                app:strokeColor="?attr/theme_accent"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="@string/btn_save"
                app:backgroundTint="?attr/theme_accent"/>
            <com.google.android.material.button.MaterialButton
                android:textColor="?attr/theme_text_secondary"
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_reset_defaults"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/theme_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/AdvSettings_HideTraffic"/>
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="?attr/theme_text_secondary"
                android:id="@+id/tilFakeSni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/pref_fake_sni"
                app:boxStrokeColor="?attr/theme_accent"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconMode="custom"
                app:endIconTint="?attr/theme_text_secondary"
                app:expandedHintEnabled="false"
                app:hintTextColor="?attr/theme_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/etFakeSni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pref_fake_sni_hint"
                    android:inputType="textUri"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="?attr/theme_text_secondary"
                android:id="@+id/tilUpstreamProxy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/pref_upstream_proxy"
                app:boxStrokeColor="?attr/theme_accent"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconMode="custom"
                app:endIconTint="?attr/theme_text_secondary"
                app:expandedHintEnabled="false"
                app:hintTextColor="?attr/theme_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/etUpstreamProxy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pref_upstream_proxy_hint"
                    android:inputType="textUri"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/theme_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/AdvSettings_dns"/>
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="?attr/theme_text_secondary"
                android:id="@+id/tilBootstrapDns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/pref_bootstrap_dns"
                app:boxStrokeColor="?attr/theme_accent"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconMode="custom"
                app:endIconTint="?attr/theme_text_secondary"
                app:expandedHintEnabled="false"
                app:hintTextColor="?attr/theme_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:textColor="?attr/theme_text_primary"
                    android:ellipsize="end"
                    android:id="@+id/etBootstrapDns"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pref_bootstrap_dns_hint"
                    android:cursorVisible="false"
                    android:singleLine="true"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="?attr/theme_text_secondary"
                android:id="@+id/tilTestUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/pref_test_url"
                app:boxStrokeColor="?attr/theme_accent"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconMode="custom"
                app:endIconTint="?attr/theme_text_secondary"
                app:expandedHintEnabled="false"
                app:hintTextColor="?attr/theme_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/etTestUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pref_test_url_hint"
                    android:inputType="textUri"/>
            </com.google.android.material.textfield.TextInputLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/item_background"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="?attr/theme_text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_tun_dns_strategy"/>
                </LinearLayout>
                <Spinner
                    android:id="@+id/spDnsStrategy"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="100dp"
                    android:spinnerMode="dropdown"
                    android:importantForAccessibility="no"/>
                <ImageView
                    android:id="@+id/ivHelpDnsStrategy"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:layout_marginStart="4dp"
                    app:tint="?attr/theme_text_secondary"/>
            </LinearLayout>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/theme_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/AdvSettings_API_description"/>
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="?attr/theme_text_secondary"
                android:id="@+id/tilApiAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/pref_api_address"
                app:boxStrokeColor="?attr/theme_accent"
                app:endIconDrawable="@android:drawable/ic_menu_sort_by_size"
                app:endIconMode="custom"
                app:endIconTint="?attr/theme_accent"
                app:expandedHintEnabled="false"
                app:hintTextColor="?attr/theme_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/etApiAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pref_api_address_hint"
                    android:inputType="textUri"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/theme_accent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_cmd_args"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/ivHelpCmdArgs"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:contentDescription="Справка"
                    android:layout_marginStart="4dp"
                    app:tint="?attr/theme_text_secondary"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:textColor="?attr/theme_text_primary"
                    android:id="@+id/swManualMode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_manual_mode"
                    android:layout_weight="1"
                    android:paddingEnd="4dp"/>
                <ImageView
                    android:id="@+id/ivHelpManualMode"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:contentDescription="Справка"
                    android:layout_marginStart="4dp"
                    app:tint="?attr/theme_text_secondary"/>
            </LinearLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:textColorHint="?attr/theme_text_secondary"
                android:id="@+id/tilCmdPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:hint="@string/AdvSettings_cmd_preview_override"
                app:boxStrokeColor="?attr/theme_accent"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconMode="custom"
                app:endIconTint="?attr/theme_text_secondary"
                app:hintTextColor="?attr/theme_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="12sp"
                    android:textColor="?attr/theme_text_primary"
                    android:gravity="top"
                    android:id="@+id/etCmdPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:inputType="textMultiLine"
                    android:fontFamily="monospace"/>
            </com.google.android.material.textfield.TextInputLayout>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/theme_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/AdvSettings_Debug"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/item_background"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">
                <TextView
                    android:textColor="?attr/theme_text_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_verbosity"
                    android:layout_weight="1"/>
                <Spinner
                    android:id="@+id/spVerbosity"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="100dp"/>
                <ImageView
                    android:id="@+id/ivHelpVerbosity"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:contentDescription="Справка"
                    android:layout_marginStart="4dp"
                    app:tint="?attr/theme_text_secondary"/>
            </LinearLayout>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/theme_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/Logs_description"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:textSize="11sp"
                    android:textColor="?attr/theme_text_secondary"
                    android:id="@+id/btnClearLog"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="@string/ClearLogs"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeTextType="uniform"
                    app:strokeColor="?attr/theme_text_secondary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:textSize="11sp"
                    android:textColor="?attr/theme_accent"
                    android:id="@+id/btnCopyLog"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="@string/CopyLogs"
                    android:layout_weight="1"
                    android:textAllCaps="false"
                    android:layout_marginEnd="4dp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeTextType="uniform"
                    app:strokeColor="?attr/theme_accent"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:textSize="11sp"
                    android:textColor="?attr/theme_accent"
                    android:id="@+id/btnSaveLog"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="@string/SaveLogs"
                    android:layout_weight="1"
                    android:textAllCaps="false"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeTextType="uniform"
                    app:strokeColor="?attr/theme_accent"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
