<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="?attr/theme_ripple">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="?attr/theme_btn_highlight"
                android:endColor="?attr/theme_btn_shadow"
                android:angle="135"
                android:type="linear"
                android:centerX="0.25"
                android:centerY="0.25"
                android:centerColor="?attr/theme_btn_base"/>
            <stroke
                android:width="2dp"
                android:color="?attr/theme_ripple"/>
        </shape>
    </item>
</ripple>
