<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_focused="true"
        android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/theme_card_fill"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="3dp"
                android:color="?attr/theme_text_primary"/>
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/theme_card_fill"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="3dp"
                android:color="?attr/theme_accent"/>
        </shape>
    </item>
    <item
        android:state_checked="true"
        android:drawable="@drawable/bg_region_card_selected"/>
    <item android:drawable="@drawable/bg_region_card"/>
</selector>
